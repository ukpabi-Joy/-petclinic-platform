# Terraform
# Local .terraform directories (provider plugins, backend cache)
**/.terraform/*

# State files — never commit (may contain secrets); managed remotely / locally only
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files that may hold secrets
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files
*.tfplan

# Keep the provider lock file (.terraform.lock.hcl) tracked.
terraform/environments/dev/tfplan
**/*.tfplan
**/.terraform/
**/*.tfstate
**/*.tfstate.backup
